# Copy this file to ".env" and fill in your own values.
# The ".env" file is git-ignored and never committed.

# --- ESB Networks account credentials ---
ESB_USERNAME=email@example.com
ESB_PASSWORD=your-password
ESB_MPRN=10000000000

# --- What to download ---
# Dataset to request from the portal (e.g. intervalkwh).
ESB_SEARCH_TYPE=intervalkwh

# Output format printed to stdout: json | csv
ESB_OUTPUT_FORMAT=json

# --- Optional ---
# User-Agent string. The server validates this; if logins start failing,
# update it to a current browser value. Leave unset to use the built-in default.
#ESB_USER_AGENT=Mozilla/5.0 (X11; Ubuntu; Linux x86_64; rv:142.0) Gecko/20100101 Firefox/142.0

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
# Use DEBUG to see the full per-request request/response trace.
LOG_LEVEL=INFO
